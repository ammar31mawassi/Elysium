{
  "name": "SocialEventMember",
  "type": "object",
  "properties": {
    "event_id": { "type": "string" },
    "university_id": { "type": "string" },
    "owner_user_id": { "type": "string" },
    "user_id": { "type": "string" },
    "participant_name": {
      "type": "string",
      "rls": {
        "read": { "$or": [{ "data.owner_user_id": "{{user.id}}" }, { "data.user_id": "{{user.id}}" }, { "user_condition": { "role": "admin" } }] }
      }
    },
    "participant_academic_year": {
      "type": "string",
      "rls": {
        "read": { "$or": [{ "data.owner_user_id": "{{user.id}}" }, { "data.user_id": "{{user.id}}" }, { "user_condition": { "role": "admin" } }] }
      }
    },
    "participant_field_of_study": {
      "type": "string",
      "rls": {
        "read": { "$or": [{ "data.owner_user_id": "{{user.id}}" }, { "data.user_id": "{{user.id}}" }, { "user_condition": { "role": "admin" } }] }
      }
    },
    "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "default": "approved" }
  },
  "required": ["event_id", "university_id", "user_id"],
  "rls": {
    "create": { "data.user_id": "{{user.id}}" },
    "read": true,
    "update": { "$or": [{ "data.user_id": "{{user.id}}" }, { "user_condition": { "role": "admin" } }] },
    "delete": { "$or": [{ "data.user_id": "{{user.id}}" }, { "user_condition": { "role": "admin" } }] }
  }
}
